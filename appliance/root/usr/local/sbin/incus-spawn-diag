#!/bin/sh
# Diagnostic dump for debugging boot issues.
# Scheduled 30s after boot by rcS.
# Output goes to the serial console (ttyS0 on QEMU, hvc0 on vfkit).

CONSOLE=""
for dev in /dev/ttyS0 /dev/hvc0 /dev/ttyAMA0; do
    [ -c "$dev" ] && CONSOLE="$dev" && break
done
[ -z "$CONSOLE" ] && exit 0

exec > "$CONSOLE" 2>&1
echo "=== incus-spawn diagnostics ==="
echo "--- kernel cmdline ---"
cat /proc/cmdline 2>&1
echo "--- appliance version ---"
cat /etc/isx-version 2>&1 || echo "(no version file)"
echo "--- processes ---"
ps aux 2>&1
echo "--- vsock forwarder ---"
pgrep -a socat 2>&1 || echo "socat not running"
echo "--- incus socket ---"
ls -la /var/lib/incus/unix.socket 2>&1 || echo "/var/lib/incus/unix.socket: not found"
ls -la /run/incus/unix.socket 2>&1 || echo "/run/incus/unix.socket: not found"
echo "--- clock ---"
date -Iseconds 2>&1
echo "--- chrony ---"
chronyc tracking 2>&1 || echo "chronyd not running"
echo "--- dmesg (last 30 lines) ---"
dmesg | tail -30 2>&1
echo "--- incusd check ---"
incus info 2>&1 || echo "incusd not responding"
echo "--- network ---"
ip addr 2>&1
echo "--- resolv.conf ---"
cat /etc/resolv.conf 2>&1
echo "=== end diagnostics ==="
