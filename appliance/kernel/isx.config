# incus-spawn VM appliance kernel configuration fragment.
# Applied on top of allnoconfig via merge_config.sh.
# Both x86_64 and aarch64 options are included; irrelevant ones are ignored.

# ---- General Setup ----
CONFIG_64BIT=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_POSIX_TIMERS=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
# Full preemption: reduces seccomp_notify latency from ~100ms (PREEMPT_NONE)
# to ~100us by letting the kernel preempt anywhere. Appropriate for a
# single-purpose VM appliance where throughput penalty is negligible.
CONFIG_PREEMPT=y
# Audit: required by dbus and Incus service sandboxing
CONFIG_AUDIT=y
CONFIG_HAVE_ARCH_AUDITSYSCALL=y
CONFIG_AUDITSYSCALL=y

CONFIG_SMP=y
CONFIG_NR_CPUS=64
CONFIG_HZ_1000=y
CONFIG_SCHED_AUTOGROUP=y

CONFIG_MODULES=n
CONFIG_BLK_DEV_INITRD=n

CONFIG_EXPERT=y
CONFIG_MULTIUSER=y
CONFIG_SYSFS_SYSCALL=y
CONFIG_FHANDLE=y
CONFIG_FILE_LOCKING=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
CONFIG_INOTIFY_USER=y
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_KALLSYMS=y
CONFIG_SYSCTL=y
CONFIG_EMBEDDED=n

# Binary format support
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ---- Mitigations off (compile-time) ----
CONFIG_CPU_MITIGATIONS=n

# ---- Block Layer ----
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8

# ---- PCI ----
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y

# ---- ACPI (x86_64 QEMU needs this for PCI and power) ----
CONFIG_ACPI=y

# ---- Virtio ----
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM_VIRTIO=y

# ---- Console / TTY ----
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_UNIX98_PTYS=y
CONFIG_LEGACY_PTYS=n

# Serial: ttyS0 (QEMU x86_64)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4

# Serial: ttyAMA0 (QEMU aarch64)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# HVC: hvc0 (vfkit macOS, via VIRTIO_CONSOLE above)
CONFIG_HVC_DRIVER=y

# ---- Filesystems ----
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_OVERLAY_FS=y
# CONFIG_OVERLAY_FS_METACOPY is not set
CONFIG_OVERLAY_FS_XATTR_USER=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_HUGETLBFS=y
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# ---- Networking ----
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_SYN_COOKIES=y
CONFIG_IPV6=y

# Netdevices
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_TUN=y
CONFIG_VETH=y
CONFIG_MACVLAN=y

# Traffic control (required by Incus for container network devices)
CONFIG_NET_SCHED=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_SCH_INGRESS=y
CONFIG_NET_SCH_FQ_CODEL=y

# Bridge
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_VLAN_8021Q=y
CONFIG_BRIDGE_VLAN_FILTERING=y

# Netfilter (nftables + iptables NAT + REDIRECT for MITM proxy)
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_CT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_FIB=y
CONFIG_NFT_FIB_INET=y
CONFIG_NFT_FIB_IPV4=y
CONFIG_NFT_FIB_IPV6=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_NUMGEN=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XTABLES_LEGACY=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NF_NAT_REDIRECT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_IPTABLES_LEGACY=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_IPTABLES_LEGACY=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_NAT=y

# ---- Container Isolation ----
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_TIME_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# cgroups
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_BPF=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_ZSWAP=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_CGROUP_IOCOST=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_WRITEBACK=y
CONFIG_CGROUP_MISC=y

# Seccomp
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# seccomp_notify performance: process_vm_readv lets incusd read syscall
# args directly from container memory instead of the slow /proc/pid/mem path
CONFIG_CROSS_MEMORY_ATTACH=y

# Checkpoint/restore: seccomp filter introspection, kcmp syscall
CONFIG_CHECKPOINT_RESTORE=y

# ---- Security ----
CONFIG_SECURITY=y
CONFIG_FANOTIFY=y

# ---- Memory ----
CONFIG_SHMEM=y
CONFIG_COMPACTION=y
CONFIG_MIGRATION=y
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_SWAP=y

# ---- Kernel Compression ----
CONFIG_KERNEL_ZSTD=y

# ---- Performance ----
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_PERF_EVENTS=y

# ---- Debugging (minimal) ----
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=-1
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_FS=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n

# ---- Hardware RNG ----
CONFIG_HW_RANDOM=y

# ---- ARM64-specific (auto-selected by arch, listed for documentation) ----
# ARM_GIC_V3 is auto-selected by arm64
# PCI_HOST_GENERIC is arm64 only (ignored on x86)
