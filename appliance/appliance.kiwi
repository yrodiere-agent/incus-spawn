<?xml version="1.0" encoding="utf-8"?>
<image schemaversion="7.5" name="incus-spawn-appliance">
    <description type="system">
        <author>incus-spawn</author>
        <contact>https://github.com/Sanne/incus-spawn</contact>
        <specification>
            Minimal openSUSE Tumbleweed VM appliance for running Incus containers.
            Designed for direct kernel boot with QEMU microvm or Apple Virtualization.framework.
        </specification>
    </description>

    <preferences>
        <version>1.0.0</version>
        <packagemanager>zypper</packagemanager>
        <rpm-excludedocs>true</rpm-excludedocs>
        <rpm-check-signatures>false</rpm-check-signatures>
        <type
            image="oem"
            filesystem="ext4"
            initrd_system="none"
            bootloader="custom"
            kernelcmdline="console=ttyS0 quiet systemd.show_status=no"
            format="qcow2"
            formatoptions="preallocation=off,lazy_refcounts=on"
            installiso="false"
        >
            <oemconfig>
                <oem-resize>false</oem-resize>
            </oemconfig>
            <size unit="G">8</size>
        </type>
    </preferences>

    <users>
        <user
            password="!"
            home="/root"
            name="root"
            groups="root"
        />
    </users>

    <repository type="rpm-md">
        <source path="obsrepositories:/"/>
    </repository>

    <packages type="image">
        <!-- Base system -->
        <package name="patterns-base-minimal_base"/>
        <package name="systemd"/>
        <package name="aaa_base"/>

        <!-- Kernel -->
        <package name="kernel-default"/>

        <!-- Networking -->
        <package name="systemd-network"/>
        <package name="iproute2"/>
        <package name="iptables"/>

        <!-- Incus -->
        <package name="incus"/>

        <!-- Storage -->
        <package name="btrfs-progs"/>

        <!-- Remote access (for testing/debugging) -->
        <package name="openssh-server"/>

        <!-- TLS -->
        <package name="ca-certificates"/>
        <package name="ca-certificates-mozilla"/>
    </packages>

    <packages type="bootstrap">
        <package name="filesystem"/>
        <package name="glibc-locale-base"/>
        <package name="ca-certificates"/>
        <package name="ca-certificates-mozilla"/>
        <package name="openSUSE-release"/>
        <package name="shadow"/>
        <package name="gawk"/>
        <package name="grep"/>
        <package name="gzip"/>
        <package name="udev"/>
        <package name="cracklib-dict-full"/>
    </packages>

    <!-- Strip the package manager from the final image -->
    <!-- TODO: Re-enable once we figure out correct package names and dependencies
    <packages type="uninstall">
        <package name="zypper"/>
        <package name="libzypp"/>
        <package name="libsolv-tools"/>
        <package name="rpm"/>
    </packages>
    -->
</image>
