[45.5802, "o", "\u001b[2D\u001b[3B\r\u001b[8A\u001b[38;5;114m●\r\u001b[1B\u001b[38;5;246m  ⎿  \u001b[39mAdded\u001b[12G\u001b[1m1\u001b[14G\u001b[22mline,\u001b[20Gremoved\u001b[28G\u001b[1m1\u001b[30G\u001b[22mline\r\u001b[1B \u001b[3G   \u001b[38;5;231m\u001b[2m  4 \u001b[22m \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m  5 \u001b[22m     \u001b[38;5;242m/** Applies a percentage discount to a price. */\r\u001b[1B\u001b[39m     \u001b[38;5;231m\u001b[2m  6 \u001b[22m     \u001b[38;5;197mpublic\u001b[38;5;231m \u001b[38;5;197mstatic\u001b[38;5;231m \u001b[38;5;148mdouble\u001b[38;5;231m \u001b[38;5;148mapplyDiscount\u001b[38;5;208m(\u001b[38;5;148mdouble\u001b[38;5;208m price, \u001b[38;5;148mdouble\u001b[38;5;208m discountPercent)\u001b[38;5;231m {\u001b[39m\u001b[K\r\u001b[1B   \u001b[6G\u001b[38;5;167m\u001b[48;5;52m  7 -\u001b[38;5;231m        return price + price * (discountPercent / 100.0);                          \r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;5;77m\u001b[48;5;22m  7 +\u001b[38;5;231m        \u001b[38;5;197mreturn\u001b[38;5;231m price \u001b[48;5;28m-\u001b[48;5;22m price * (discountPercent / \u001b[38;5;141m100.0\u001b[38;5;231m);                          \u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;5;231m\u001b[2m  8 \u001b[22m     }\u001b[39m\u001b[K\r\r\n\u001b[6G\u001b[38;5;231m\u001b[2m \u001b[8G9\u001b[10G\u001b[22m \u001b[39m\r\r\n\u001b[6G\u001b[38;5;231m\u001b[2m 10\u001b[10G\u001b[22m \u001b[15G\u001b[38;5;"]
